# ============================================
# CyberShield AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys

# VirusTotal API (URL scanning)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Google Safe Browsing API (phishing URL detection)
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here

# Reality Defender API (deepfake detection - 50 scans)
REALITY_DEFENDER_API_KEY=your_reality_defender_api_key_here

# Groq API (LLM explainer - llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_api_key_here

# SERP API (optional - live threat intelligence)
SERP_API_KEY=your_serp_api_key_here

# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
